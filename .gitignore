# ==============================================================================
# Environment / secrets
# ==============================================================================
# Never commit real credentials, database passwords, or pgAdmin passwords.
.env
.env.*
!.env.example


# ==============================================================================
# Database backups
# ==============================================================================
# Backups may contain real production data and should never be committed.
database/backups/*
!database/backups/.gitkeep


# ==============================================================================
# PostgreSQL / database runtime files
# ==============================================================================
# Ignore any accidental local database data folders if bind mounts are used later.
database/data/
database/db-data/
postgres-data/
pgdata/


# ==============================================================================
# Logs
# ==============================================================================
logs/
*.log
*.out
*.err


# ==============================================================================
# Docker / local runtime artifacts
# ==============================================================================
.docker/
docker-compose.override.yml


# ==============================================================================
# OS generated files
# ==============================================================================
.DS_Store
Thumbs.db


# ==============================================================================
# Editor / IDE files
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo


# ==============================================================================
# Temporary files
# ==============================================================================
tmp/
temp/
*.tmp
*.bak
*.backup


# ==============================================================================
# Keep important project files tracked
# ==============================================================================
!docker-compose.yml
!README.md
!database/init/
!database/init/*.sh
!scripts/
!scripts/*.sh